#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080/'

#--------------------------------------------------------------------
# DATABASE — Conexion principal
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = propiedad_horizontal
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Para DigitalOcean Managed MySQL (produccion):
# database.default.port = 25060
# database.default.encrypt = TRUE
# database.default.encrypt.ssl_cert = /ruta/ca-certificate.crt
# database.default.encrypt.ssl_verify = TRUE

#--------------------------------------------------------------------
# DATABASE — Conexion readonly (portal cliente)
#--------------------------------------------------------------------

# readonly.hostname = localhost
# readonly.database = propiedad_horizontal
# readonly.username = usuario_readonly
# readonly.password =
# readonly.port = 3306
# readonly.encrypt = TRUE

#--------------------------------------------------------------------
# API KEYS — Servicios externos
#--------------------------------------------------------------------

# Email transaccional (SendGrid o Brevo)
SENDGRID_API_KEY=

# IA — OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# IA — Anthropic (solo herramienta de clasificacion de PDFs)
# ANTHROPIC_API_KEY=

#--------------------------------------------------------------------
# TOKENS INTERNOS
#--------------------------------------------------------------------

# Token para endpoints API internos
APP_API_KEY=

# Token para endpoints cron via HTTP
CRON_TOKEN=changeme

#--------------------------------------------------------------------
# RUTAS
#--------------------------------------------------------------------

# Ruta de uploads de clientes (fuera de git)
# UPLOADS_PATH = /ruta/a/soportes-clientes/

